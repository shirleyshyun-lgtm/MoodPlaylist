{
  "version": 2,
  "builds": [
    { "src": "api/generate.js", "use": "@vercel/node" },
    { "src": "api/admin-stats.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/api/admin/stats", "dest": "/api/admin-stats.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
